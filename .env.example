#
HOST=127.0.0.1
PORT=3000
NEXT_PUBLIC_SITE_URL=https://smartcardio.ru

CDEK_IS_PRODUCTION=true
#   true  - прокси smartcardio (https://lk.smartcardio.ru/cdek), credentials передаются в query-параметрах
#   false - тестовый домен СДЭК (https://api.edu.cdek.ru), стандартный OAuth2 x-www-form-urlencoded запрос
CDEK_BASE_URL=https://lk.smartcardio.ru/cdek/v2
# Базовый URL СДЭК
# Для тестового режима (IS_PRODUCTION=false) укажите: https://api.edu.cdek.ru/v2
CDEK_CLIENT_ID=xxxxxxxxxxxxxxxx
CDEK_CLIENT_SECRET=xxxxxxxxxxxxxxxx

# Partner API — сервис промокодов, Базовый URL партнёрского API (без слеша на конце)
PARTNER_API=https://partner-api.example.com
# Ключ для авторизации запросов к Partner API (передаётся в заголовке X-API-KEY)
X_API_KEY=xxxxxxxxxxxxxxxxxxxx

SMTP_HOST=127.0.0.1
SMTP_PORT=25
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=xxxxxxxxxxxxx
# Отправитель, если не задан — берётся SMTP_USER, иначе noreply@smartcardio.ru
SMTP_FROM=sender@example.com

REVIEW_EMAIL_TO=admin@smartcardio.ru
# Email, на который приходят вопросы с сайта (форма "Задать вопрос")
QUESTION_EMAIL_TO=admin@smartcardio.ru
